<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:OpenTalkie.Presentation.ViewModels;assembly=OpenTalkie.Presentation"
             x:Class="OpenTalkie.Presentation.Views.AddStreamPage"
             Title="Add New Stream"
             Padding="16"
             x:DataType="viewmodel:AddStreamViewModel">

    <ContentPage.Resources>
        <Style x:Key="StreamCardStyle" TargetType="Border" BasedOn="{StaticResource M3CardBorder}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        </Style>
        <Style x:Key="InputLabelStyle" TargetType="Label">
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="SectionLabelStyle" TargetType="Label">
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}" />
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="VerticalOptions" Value="Center"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0"> <!-- Reduced global spacing, cards handle spacing -->
            
            <!-- Name -->
            <Border Style="{StaticResource StreamCardStyle}">
                <!-- TapGestureRecognizer moved to the Grid below -->
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditNameCommand}"/>
                    </Grid.GestureRecognizers>
                    <Label Grid.Row="0" Grid.Column="0" Text="Stream Name" Style="{StaticResource SectionLabelStyle}"/>
                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding DisplayName}" Style="{StaticResource InputLabelStyle}"/>
                    <Image Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Source="edit_icon.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" Opacity="0.7"/>
                </Grid>
            </Border>

            <!-- Hostname -->
            <Border Style="{StaticResource StreamCardStyle}">
                <!-- TapGestureRecognizer moved to the Grid below -->
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditHostnameCommand}"/>
                    </Grid.GestureRecognizers>
                    <Label Grid.Row="0" Grid.Column="0" Text="Hostname or IP Address" Style="{StaticResource SectionLabelStyle}"/>
                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding DisplayHostname}" Style="{StaticResource InputLabelStyle}"/>
                    <Image Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Source="edit_icon.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" Opacity="0.7"/>
                </Grid>
            </Border>

            <!-- Port -->
            <Border Style="{StaticResource StreamCardStyle}">
                <!-- TapGestureRecognizer moved to the Grid below -->
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditPortCommand}"/>
                    </Grid.GestureRecognizers>
                    <Label Grid.Row="0" Grid.Column="0" Text="Port" Style="{StaticResource SectionLabelStyle}"/>
                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding DisplayPort}" Style="{StaticResource InputLabelStyle}"/>
                    <Image Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Source="edit_icon.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" Opacity="0.7"/>
                </Grid>
            </Border>

            <!-- Net Quality -->
            <Border Style="{StaticResource StreamCardStyle}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditQualityCommand}"/>
                    </Grid.GestureRecognizers>
                    <Label Grid.Row="0" Grid.Column="0" Text="Net Quality" Style="{StaticResource SectionLabelStyle}"/>
                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding DisplayQuality}" Style="{StaticResource InputLabelStyle}"/>
                    <Image Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Source="edit_icon.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" Opacity="0.7"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource StreamCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Enable Denoise" Style="{StaticResource SectionLabelStyle}"/>
                    <Switch Grid.Column="1" IsToggled="{Binding IsDenoiseEnabled}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource StreamCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Enable On Mobile Data" Style="{StaticResource SectionLabelStyle}"/>
                    <Switch Grid.Column="1" IsToggled="{Binding AllowMobileData}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource StreamCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Enable Stream" Style="{StaticResource SectionLabelStyle}"/>
                    <Switch Grid.Column="1" IsToggled="{Binding IsEnabled}"/>
                </Grid>
            </Border>

            <Grid ColumnSpacing="10" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource FilledButton}" Text="Save" Command="{Binding SaveCommand}"/>
                <Button Grid.Column="1" Style="{StaticResource OutlinedButton}" Text="Cancel" Command="{Binding CancelCommand}"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>


